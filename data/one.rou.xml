<?xml version="1.0" encoding="UTF-8"?>
<routes>
  <!-- 外部制御前提（Rail+SpeedMode=0を想定） -->
  <vType id="ext" length="5" accel="3" decel="7" sigma="0" carFollowModel="Rail"/>

  <!-- あなたのネットのエッジIDは A0B0 -->
  <route id="r" edges="A0B0"/>

  <!-- 先頭から x=0, 60, 120, ... 420m に等間隔配置（20 m/sで開始） -->
  <!-- 並び：Lead → Head → HV×5 → Tail -->
  <vehicle id="lead" type="ext" route="r" depart="0.0" departPos="0"    departSpeed="20"/>
  <vehicle id="head" type="ext" route="r" depart="0.0" departPos="60"   departSpeed="20"/>
  <vehicle id="hv1"  type="ext" route="r" depart="0.0" departPos="120"  departSpeed="20"/>
  <vehicle id="hv2"  type="ext" route="r" depart="0.0" departPos="180"  departSpeed="20"/>
  <vehicle id="hv3"  type="ext" route="r" depart="0.0" departPos="240"  departSpeed="20"/>
  <vehicle id="hv4"  type="ext" route="r" depart="0.0" departPos="300"  departSpeed="20"/>
  <vehicle id="hv5"  type="ext" route="r" depart="0.0" departPos="360"  departSpeed="20"/>
  <vehicle id="tail" type="ext" route="r" depart="0.0" departPos="420"  departSpeed="20"/>
</routes>

